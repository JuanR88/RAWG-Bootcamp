            )
        else:
            if "año" in p_lower or "anio" in p_lower:
                sql = "SELECT released, platforms FROM juego LIMIT 100;"
            else:
                sql = "SELECT platforms FROM juego LIMIT 100;"

    else:
        prompt = construir_prompt(p)
